/*
 * IchigoJam_Z - Raspberry Pi Pico device tree overlay
 *
 * The base rpi_pico BSP already configures:
 *   uart0: GPIO0 (TX), GPIO1 (RX), 115200 baud
 *   i2c0:  GPIO4 (SDA), GPIO5 (SCL)
 *   gpio0: enabled
 *
 * This overlay:
 *   - Defines flash partitions (app: 1.75MB, storage: 256KB)
 *   - Overrides pwm_ch4b pinctrl from GPIO25 (LED) to
 *     GPIO20 (SOUND output) for the PSG timer thread (M3).
 *   - Enables ADC for IN1(GPIO27), IN2(GPIO26), BTN(GPIO28)
 */

#include <zephyr/dt-bindings/pinctrl/rpi-pico-rp2040-pinctrl.h>

/*
 * Flash partitions: 2MB total, last 256KB reserved for NVS storage.
 * The base rpi_pico-common.dtsi defines code_partition spanning all
 * usable flash. We delete it and redefine it smaller, then add
 * storage_partition in the freed space.
 */
&flash0 {
	partitions {
		/delete-node/ partition@100;

		/* Application code: 0x100 .. 0x1BFFFF (1.75MB - 256B) */
		code_partition: partition@100 {
			label = "code-partition";
			reg = <0x00000100 (DT_SIZE_K(1792) - 0x100)>;
			read-only;
		};

		/* NVS storage: last 256KB (64 sectors x 4KB) */
		storage_partition: partition@1C0000 {
			label = "storage";
			reg = <0x001C0000 DT_SIZE_K(256)>;
		};
	};
};

&pwm {
	status = "okay";
	pinctrl-0 = <&pwm_ch2a_sound>;
	pinctrl-names = "default";
};

&pinctrl {
	pwm_ch2a_sound: pwm_ch2a_sound {
		group1 {
			pinmux = <PWM_2A_P20>;
		};
	};
};

/ {
	zephyr,user {
		/* IchigoJam GPIO pin assignments for Raspberry Pi Pico */
		ij-led-gpios  = <&gpio0 25 GPIO_ACTIVE_HIGH>;   /* onboard LED */
		ij-btn-gpios  = <&gpio0 28 GPIO_ACTIVE_LOW>;    /* BTN, pull-up */
		ij-out1-gpios = <&gpio0  8 GPIO_ACTIVE_HIGH>;
		ij-out2-gpios = <&gpio0  9 GPIO_ACTIVE_HIGH>;
		ij-out3-gpios = <&gpio0 10 GPIO_ACTIVE_HIGH>;
		ij-out4-gpios = <&gpio0 11 GPIO_ACTIVE_HIGH>;
		ij-out5-gpios = <&gpio0 22 GPIO_ACTIVE_HIGH>;
		ij-out6-gpios = <&gpio0 21 GPIO_ACTIVE_HIGH>;
		ij-in1-gpios  = <&gpio0 27 GPIO_ACTIVE_HIGH>;   /* ADC ch1 */
		ij-in2-gpios  = <&gpio0 26 GPIO_ACTIVE_HIGH>;   /* ADC ch0 */
		ij-in3-gpios  = <&gpio0  6 GPIO_ACTIVE_HIGH>;
		ij-in4-gpios  = <&gpio0  7 GPIO_ACTIVE_HIGH>;
	};
};

&adc {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	channel@0 {
		reg = <0>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <10>;
		zephyr,input-positive = <0>;  /* IN2: GPIO26 = ADC ch0 */
	};

	channel@1 {
		reg = <1>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <10>;
		zephyr,input-positive = <1>;  /* IN1: GPIO27 = ADC ch1 */
	};

	channel@2 {
		reg = <2>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <10>;
		zephyr,input-positive = <2>;  /* BTN: GPIO28 = ADC ch2 */
	};
};
