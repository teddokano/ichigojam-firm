/*
 * IchigoJam_Z - Raspberry Pi Pico device tree overlay
 *
 * The base rpi_pico BSP already configures:
 *   uart0: GPIO0 (TX), GPIO1 (RX), 115200 baud
 *   i2c0:  GPIO4 (SDA), GPIO5 (SCL)
 *   gpio0: enabled
 *
 * This overlay:
 *   - Defines flash partitions (app: 1.75MB, storage: 256KB)
 *   - Overrides pwm_ch4b pinctrl from GPIO25 (LED) to
 *     GPIO20 (SOUND output) for the PSG timer thread (M3).
 *   - Enables ADC for IN1(GPIO27), IN2(GPIO26), BTN(GPIO28)
 */

#include <zephyr/dt-bindings/pinctrl/rpi-pico-rp2040-pinctrl.h>
#include <zephyr/dt-bindings/pwm/pwm.h>

/*
 * Flash partitions: 2MB total, last 256KB reserved for NVS storage.
 * The base rpi_pico-common.dtsi defines code_partition spanning all
 * usable flash. We delete it and redefine it smaller, then add
 * storage_partition in the freed space.
 */
&flash0 {
	partitions {
		/delete-node/ partition@100;

		/* Application code: 0x100 .. 0x1BFFFF (1.75MB - 256B) */
		code_partition: partition@100 {
			label = "code-partition";
			reg = <0x00000100 (DT_SIZE_K(1792) - 0x100)>;
			read-only;
		};

		/* NVS storage: last 256KB (64 sectors x 4KB) */
		storage_partition: partition@1C0000 {
			label = "storage";
			reg = <0x001C0000 DT_SIZE_K(256)>;
		};
	};
};

&pwm {
	status = "okay";
	pinctrl-0 = <&pwm_ch2a_sound>;
	pinctrl-names = "default";
};

&pinctrl {
	pwm_ch2a_sound: pwm_ch2a_sound {
		group1 {
			pinmux = <PWM_2A_P20>;
		};
	};
};

/ {
	chosen {
		ij-adc        = &adc;    /* ADC device for ANA()/IN() */
		ij-i2c        = &i2c0;  /* I2C device for I2C() command */
		ij-cvbs-timer = &timer;  /* Counter device for CVBS line timer (M6) */
	};

	zephyr,user {
		/* IchigoJam GPIO pin assignments for Raspberry Pi Pico */
		ij-led-gpios  = <&gpio0 25 GPIO_ACTIVE_HIGH>;   /* onboard LED */
		ij-btn-gpios  = <&gpio0 28 GPIO_ACTIVE_LOW>;    /* BTN, pull-up */
		ij-out1-gpios = <&gpio0  8 GPIO_ACTIVE_HIGH>;
		ij-out2-gpios = <&gpio0  9 GPIO_ACTIVE_HIGH>;
		ij-out3-gpios = <&gpio0 10 GPIO_ACTIVE_HIGH>;
		ij-out4-gpios = <&gpio0 11 GPIO_ACTIVE_HIGH>;
		ij-out5-gpios = <&gpio0 22 GPIO_ACTIVE_HIGH>;
		ij-out6-gpios = <&gpio0 21 GPIO_ACTIVE_HIGH>;
		ij-in1-gpios  = <&gpio0 27 GPIO_ACTIVE_HIGH>;   /* ADC ch1 */
		ij-in2-gpios  = <&gpio0 26 GPIO_ACTIVE_HIGH>;   /* ADC ch0 */
		ij-in3-gpios  = <&gpio0  6 GPIO_ACTIVE_HIGH>;
		ij-in4-gpios  = <&gpio0  7 GPIO_ACTIVE_HIGH>;
		/* M6: CVBS video output pins */
		ij-cvbs-sync-gpios  = <&gpio0 16 GPIO_ACTIVE_HIGH>;  /* SYNC → 470Ω → CVBS */
		ij-cvbs-video-gpios = <&gpio0 17 GPIO_ACTIVE_HIGH>;  /* VIDEO→ 100Ω → CVBS */

		/*
		 * PWM specs for IchigoJam sound and OUT PWM outputs.
		 * Use standard "pwms" property (requires #pwm-cells = <3> on &pwm)
		 * with "pwm-names" for named access via PWM_DT_SPEC_GET_BY_NAME.
		 *
		 * RP2040 channel = gpio_pin % 16 (RP2040 PWM driver convention):
		 *   GPIO20 → ch 4 (sound)
		 *   GPIO8  → ch 8 (out1),  GPIO9  → ch 9 (out2)
		 *   GPIO10 → ch10 (out3),  GPIO11 → ch11 (out4)
		 *   GPIO22 → ch 6 (out5),  GPIO21 → ch 5 (out6)
		 *
		 * Runtime pinmux (GPIO→PWM) for OUT pins is set via direct
		 * IO_BANK0.GPIO_CTRL[n].FUNCSEL register access in ichigojam-io.h
		 * because Zephyr has no runtime pinmux API.
		 * Period dummy values; actual period set by pwm_set() at runtime.
		 */
		pwms = <&pwm  4 1000     PWM_POLARITY_NORMAL>,  /* sound */
		       <&pwm  8 20000000 PWM_POLARITY_NORMAL>,  /* out1  */
		       <&pwm  9 20000000 PWM_POLARITY_NORMAL>,  /* out2  */
		       <&pwm 10 20000000 PWM_POLARITY_NORMAL>,  /* out3  */
		       <&pwm 11 20000000 PWM_POLARITY_NORMAL>,  /* out4  */
		       <&pwm  6 20000000 PWM_POLARITY_NORMAL>,  /* out5  */
		       <&pwm  5 20000000 PWM_POLARITY_NORMAL>;  /* out6  */
		pwm-names = "sound", "out1", "out2", "out3", "out4", "out5", "out6";
	};
};

/*
 * CVBS タイマー (RP2040 hardware timer alarm0)
 *
 * alarm0 の IRQ 優先度を 0 (最高) に設定する。
 * Cortex-M0+ は 2-bit 優先度 (0=最高, 3=最低)。
 * 優先度 0 により Zephyr カーネル tick (SysTick/alarm3 = 優先度 3) を含む
 * 全ての割り込みが CVBS ISR を割り込めなくなり、H-sync 周期が安定する。
 * RP2040 は BASEPRI 非搭載のため CONFIG_ZERO_LATENCY_IRQS は無効であり、
 * 優先度 0 でも Zephyr API (counter_set_channel_alarm 等) を安全に呼べる。
 *
 * 優先度マッピング (Cortex-M0+ 2bit: 0=最高 … 3=最低):
 *   alarm0: 0 (CVBS 専用 — 最高優先度)
 *   alarm1-3: 3 (デフォルト)
 */
&timer {
	status = "okay";
	interrupts = <0 0>,  /* alarm0: CVBS — 最高優先度 */
		     <1 3>,
		     <2 3>,
		     <3 3>;
};

/* I2C0: GPIO4 (SDA), GPIO5 (SCL) — already pinctrl'd in BSP, just enable */
&i2c0 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;
};

&adc {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	channel@0 {
		reg = <0>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <10>;
		zephyr,input-positive = <0>;  /* IN2: GPIO26 = ADC ch0 */
	};

	channel@1 {
		reg = <1>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <10>;
		zephyr,input-positive = <1>;  /* IN1: GPIO27 = ADC ch1 */
	};

	channel@2 {
		reg = <2>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <10>;
		zephyr,input-positive = <2>;  /* BTN: GPIO28 = ADC ch2 */
	};
};
