/*
 * IchigoJam_Z - FRDM-MCXC444 device tree overlay
 *
 * Base BSP already provides:
 *   lpuart0: console at 115200 baud (PTA1/PTA2)
 *   adc0:    enabled, pinmux_adc0 has PTE20(SE0) and PTE22(SE3)
 *   i2c0:    enabled at PTE24(SCL)/PTE25(SDA), FXLS8974 accel at 0x18
 *   tpm0:    enabled, CH2=PTE29(blue LED), CH4=PTE31(red LED), CH5=PTD5(green LED)
 *   gpioa-e: all enabled
 *   flash0:  storage_partition at 0x38000 (32KB) — already correct, no change needed
 *
 * This overlay adds:
 *   tpm0: CH1=PTA4(OUT3), CH2=PTA5(OUT4), CH3=PTD3(OUT1), CH3=PTE30(OUT6)
 *         (CH2=PTE29/OUT5 already in BSP group0)
 *   tpm1: CH0=PTA12(OUT2)
 *   tpm2: CH0=PTB18(SOUND)
 *   adc0: adds PTB0-3 (SE8/SE9/SE12/SE13) for IN1-IN4
 *   i2c1: PTE0(SDA)/PTE1(SCL) for user I2C (D18/D19)
 *
 * Pin assignments (Arduino header):
 *   LED    PTE31 (GPIOE 31, active LOW)   — onboard Red LED
 *   BTN    PTC3  (GPIOC  3, active LOW)   — SW2
 *   OUT1   PTD3  / TPM0_CH3  / D2
 *   OUT2   PTA12 / TPM1_CH0  / D3
 *   OUT3   PTA4  / TPM0_CH1  / D4  [SW3/user_button_3 shared pin]
 *   OUT4   PTA5  / TPM0_CH2  / D5
 *   OUT5   PTE29 / TPM0_CH2  / D6  [BLUE LED shared pin, active LOW]
 *   OUT6   PTE30 / TPM0_CH3  / D7
 *   SOUND  PTB18 / TPM2_CH0      — J4 inner row, D0 内側端子
 *   IN1/ANA(1)  PTB0 — ADC0_SE8  (Arduino A0)
 *   IN2/ANA(2)  PTB1 — ADC0_SE9  (Arduino A1)
 *   IN3/ANA(3)  PTB2 — ADC0_SE12 (Arduino A2)
 *   IN4/ANA(4)  PTB3 — ADC0_SE13 (Arduino A3)
 *   I2C SCL     PTE1 (I2C1_SCL)  / D19
 *   I2C SDA     PTE0 (I2C1_SDA)  / D18
 *
 * Kinetis TPM module constraints (shared period register per module):
 *   TPM0 (shared period): OUT1(CH3), OUT3(CH1), OUT4(CH2), OUT5(CH2)*, OUT6(CH3)*
 *     * OUT4 and OUT5 share TPM0_CH2 → same duty cycle when both active
 *     * OUT1 and OUT6 share TPM0_CH3 → same duty cycle when both active
 *   TPM1 (independent):   OUT2(CH0)
 *   TPM2 (independent):   SOUND(CH0) — BEEP/PLAY will not interfere with OUT PWM
 *
 * i2c0 (PTE24/PTE25) is reserved for onboard FXLS8974 accelerometer ("no availability").
 * User I2C must use i2c1 (PTE0/PTE1 = D18/D19).
 */

#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/pwm/pwm.h>

&pinctrl {
	/* Add OUT1/3/4/6 channels to existing tpm0 pinctrl.
	 * BSP group0 already has CH2=PTE29(blue LED/OUT5), CH4=PTE31(red LED),
	 * CH5=PTD5(green LED). New group adds remaining OUT channels. */
	pinmux_tpm0: pinmux_tpm0 {
		group_out {
			pinmux = <TPM0_CH3_PTD3>,   /* OUT1: D2  */
				 <TPM0_CH1_PTA4>,   /* OUT3: D4  */
				 <TPM0_CH2_PTA5>,   /* OUT4: D5  */
				 <TPM0_CH3_PTE30>;  /* OUT6: D7  */
			drive-strength = "low";
			slew-rate = "slow";
		};
	};

	/* TPM1: OUT2 = PTA12 / D3 */
	pinmux_tpm1_out: pinmux_tpm1_out {
		group0 {
			pinmux = <TPM1_CH0_PTA12>;
			drive-strength = "low";
			slew-rate = "slow";
		};
	};

	/* TPM2: SOUND = PTB18 (J4 inner row, D0 内側端子) */
	pinmux_tpm2_out: pinmux_tpm2_out {
		group0 {
			pinmux = <TPM2_CH0_PTB18>;
			drive-strength = "low";
			slew-rate = "slow";
		};
	};

	/* I2C1: PTE0(SDA)/PTE1(SCL) = D18/D19 Arduino header */
	pinmux_i2c1: pinmux_i2c1 {
		group0 {
			pinmux = <I2C1_SDA_PTE0>,
				 <I2C1_SCL_PTE1>;
			drive-strength = "low";
			drive-open-drain;
			slew-rate = "fast";
		};
	};

	/* Add IN1-IN4 ADC channels (PTB0-3) to existing adc0 pinctrl.
	 * BSP group0 has PTE20(SE0)/PTE22(SE3) — unused but harmless. */
	pinmux_adc0: pinmux_adc0 {
		group_ptb {
			pinmux = <ADC0_SE8_PTB0>,
				 <ADC0_SE9_PTB1>,
				 <ADC0_SE12_PTB2>,
				 <ADC0_SE13_PTB3>;
			drive-strength = "low";
			slew-rate = "slow";
		};
	};
};

/* Enable TPM1 for OUT2 (PTA12 / D3) */
&tpm1 {
	status = "okay";
	pinctrl-0 = <&pinmux_tpm1_out>;
	pinctrl-names = "default";
	clocks = <&sim KINETIS_SIM_CLOCK(KINETIS_SIM_MCGPCLK, 0x103c, 25)>;
};

/* Enable TPM2 for SOUND (PTB18 / J4 inner row D0) */
&tpm2 {
	status = "okay";
	pinctrl-0 = <&pinmux_tpm2_out>;
	pinctrl-names = "default";
	clocks = <&sim KINETIS_SIM_CLOCK(KINETIS_SIM_MCGPCLK, 0x103c, 26)>;
};

/* Enable I2C1 for user I2C (D18=SDA/PTE0, D19=SCL/PTE1) */
&i2c1 {
	status = "okay";
	pinctrl-0 = <&pinmux_i2c1>;
	pinctrl-names = "default";
	clock-frequency = <I2C_BITRATE_FAST>;
};

/ {
	chosen {
		ij-adc = &adc0;   /* ADC device for ANA()/IN() */
		ij-i2c = &i2c1;  /* I2C device for I2C() command */
	};

	zephyr,user {
		/* IchigoJam GPIO pin assignments for FRDM-MCXC444 */
		ij-led-gpios  = <&gpioe 31 GPIO_ACTIVE_LOW>;   /* RED LED (PTE31) */
		ij-btn-gpios  = <&gpioc  3 GPIO_ACTIVE_LOW>;   /* SW2 (PTC3) */
		ij-out1-gpios = <&gpiod  3 GPIO_ACTIVE_HIGH>;  /* PTD3  / D2 */
		ij-out2-gpios = <&gpioa 12 GPIO_ACTIVE_HIGH>;  /* PTA12 / D3 */
		ij-out3-gpios = <&gpioa  4 GPIO_ACTIVE_HIGH>;  /* PTA4  / D4 (SW3 shared) */
		ij-out4-gpios = <&gpioa  5 GPIO_ACTIVE_HIGH>;  /* PTA5  / D5 */
		ij-out5-gpios = <&gpioe 29 GPIO_ACTIVE_HIGH>;  /* PTE29 / D6 (BLUE LED shared) */
		ij-out6-gpios = <&gpioe 30 GPIO_ACTIVE_HIGH>;  /* PTE30 / D7 */
		ij-in1-gpios  = <&gpiob  0 GPIO_ACTIVE_HIGH>;  /* PTB0 = ADC0_SE8  / A0 */
		ij-in2-gpios  = <&gpiob  1 GPIO_ACTIVE_HIGH>;  /* PTB1 = ADC0_SE9  / A1 */
		ij-in3-gpios  = <&gpiob  2 GPIO_ACTIVE_HIGH>;  /* PTB2 = ADC0_SE12 / A2 */
		ij-in4-gpios  = <&gpiob  3 GPIO_ACTIVE_HIGH>;  /* PTB3 = ADC0_SE13 / A3 */

		/*
		 * PWM specs for IchigoJam sound and OUT PWM outputs.
		 *
		 * Kinetis TPM: each module has ONE shared period register.
		 *   TPM0 (shared): OUT1(CH3/PTD3), OUT3(CH1/PTA4), OUT4(CH2/PTA5),
		 *                  OUT5(CH2/PTE29)*, OUT6(CH3/PTE30)*
		 *   TPM1 (independent): OUT2(CH0/PTA12)
		 *   TPM2 (independent): SOUND(CH0/PTB18)
		 *
		 * Hardware channel conflicts (same TPM channel → same duty cycle):
		 *   OUT4(TPM0_CH2/PTA5) == OUT5(TPM0_CH2/PTE29)  → PWM 4 and PWM 5 share CH2
		 *   OUT1(TPM0_CH3/PTD3) == OUT6(TPM0_CH3/PTE30)  → PWM 1 and PWM 6 share CH3
		 *
		 * Period dummy values; actual period set by pwm_set() at runtime.
		 */
		pwms = <&tpm2 0 1000     PWM_POLARITY_NORMAL>,  /* sound: TPM2_CH0/PTB18 */
		       <&tpm0 3 20000000 PWM_POLARITY_NORMAL>,  /* out1:  TPM0_CH3/PTD3  */
		       <&tpm1 0 20000000 PWM_POLARITY_NORMAL>,  /* out2:  TPM1_CH0/PTA12 */
		       <&tpm0 1 20000000 PWM_POLARITY_NORMAL>,  /* out3:  TPM0_CH1/PTA4  */
		       <&tpm0 2 20000000 PWM_POLARITY_NORMAL>,  /* out4:  TPM0_CH2/PTA5  */
		       <&tpm0 2 20000000 PWM_POLARITY_NORMAL>,  /* out5:  TPM0_CH2/PTE29 (=CH2, same as out4) */
		       <&tpm0 3 20000000 PWM_POLARITY_NORMAL>;  /* out6:  TPM0_CH3/PTE30 (=CH3, same as out1) */
		pwm-names = "sound", "out1", "out2", "out3", "out4", "out5", "out6";

		/*
		 * PORT_PCR restore table for GPIO→TPM pin-mux recovery.
		 * Kinetis MCX-C lacks a Zephyr runtime pinmux API (same limitation
		 * as RP2040). Each OUT1-6 entry encodes [PORT_base, pin, tpm_mux]
		 * for ichigojam-io.h to restore TPM function via direct PCR writes
		 * after a GPIO operation switches the pin back to ALT1.
		 *   PORT base addresses: A=0x40049000 B=0x4004A000 C=0x4004B000
		 *                        D=0x4004C000 E=0x4004D000
		 *   TPM mux values: ALT3=3 (PTA/PTE TPM pins), ALT4=4 (PTD TPM pins)
		 */
		ij-out-tpm-pcr =
			<0x4004C000  3 4>,  /* OUT1: PORTD, pin  3, ALT4=TPM0_CH3 */
			<0x40049000 12 3>,  /* OUT2: PORTA, pin 12, ALT3=TPM1_CH0 */
			<0x40049000  4 3>,  /* OUT3: PORTA, pin  4, ALT3=TPM0_CH1 */
			<0x40049000  5 3>,  /* OUT4: PORTA, pin  5, ALT3=TPM0_CH2 */
			<0x4004D000 29 3>,  /* OUT5: PORTE, pin 29, ALT3=TPM0_CH2 */
			<0x4004D000 30 3>;  /* OUT6: PORTE, pin 30, ALT3=TPM0_CH3 */
	};
};
