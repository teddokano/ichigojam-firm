/*
 * IchigoJam_Z - FRDM-MCXA153 device tree overlay
 *
 * Base DTS already provides:
 *   lpuart0: console at 115200 baud (zephyr,console)
 *   lpi2c0:  I2C (arduino_i2c alias)
 *   lpadc0:  ADC
 *   gpio0-3: enabled
 *   storage_partition: 16KB at 0x1c000
 *   flexpwm0_pwm0: P3_6/P3_7  → PWM 1/2 (sm0 chA/B)
 *
 * This overlay adds:
 *   ctimer0:        sound output → D13 / P2_12 (CT0_MAT0)
 *   ctimer1:        CVBS line timer (M7) — 1MHz tick (prescale=95)
 *   flexpwm0_pwm1:  PWM 3/4    → P3_8  / P3_9  (sm1 chA/B)
 *   flexpwm0_pwm2:  PWM 5/6    → P3_10 / P3_11 (sm2 chA/B)
 *
 * CVBS 回路 (M7):
 *   P3_14(SYNC) ─── 470Ω ──┬── CVBS出力 (75Ω終端テレビへ)
 *   P3_15(VIDEO)─── 100Ω ──┘
 *   D9 = P3_14 (SYNC),  D8 = P3_15 (VIDEO)
 */

#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/pwm/pwm.h>

/*
 * CVBS ライン ISR タイマー: CTimer1
 * prescale = 95 → 96MHz / (95+1) = 1MHz → 1tick = 1µs (NTSC 64µs ライン周期に整合)
 * CTimer0 は SOUND (BEEP/PLAY) で使用中のため CTimer1 を使用する。
 * 割り込み優先度 0 (Cortex-M33 最高): Zephyr カーネル tick (SysTick/優先度1) を
 * CVBS ISR が割り込まれないようにする。
 */
&ctimer1 {
	status = "okay";
	prescale = <95>;
};

/*
 * CVBS ピクセルクロック: CTimer2 (M7)
 * prescale = 0 → 96MHz。MR0/MCR は video_on() で直接設定する。
 * IRQ 41 は video_on() で irq_disable() して CPU 割り込みを防ぐ。
 * DMA request source: kDma0RequestMuxCtimer2M0 = 35
 */
&ctimer2 {
	status = "okay";
	/* prescale デフォルト = 0 (DTSI より) → PR = 0 (96MHz) */
};

/*
 * EDMA0 (M7): CTimer2-triggered DMA でピクセルデータを GPIO3 PDOR に転送。
 * status = "okay" により board.c が RESET_ReleasePeripheralReset(kDMA_RST_SHIFT_RSTn)
 * を実行し DMA0 をリセットから解放する。CH3 を直接レジスタアクセスで使用。
 */
&edma0 {
	status = "okay";
};

/* Sound: CTimer0, CT0_MAT0 → D13 (P2_12) */
&ctimer0 {
	compatible = "nxp,ctimer-pwm";
	status = "okay";
	pinctrl-0 = <&ctimer0_sound>;
	pinctrl-names = "default";
	#pwm-cells = <3>;
	prescaler = <1>;
};

/* PWM 3/4: FlexPWM0 sub-module 1 → P3_8 (chA) / P3_9 (chB) */
&flexpwm0_pwm1 {
	status = "okay";
	pinctrl-0 = <&flexpwm0_pwm1_pins>;
	pinctrl-names = "default";
};

/* PWM 5/6: FlexPWM0 sub-module 2 → P3_10 (chA) / P3_11 (chB) */
&flexpwm0_pwm2 {
	status = "okay";
	pinctrl-0 = <&flexpwm0_pwm2_pins>;
	pinctrl-names = "default";
};

&pinctrl {
	ctimer0_sound: ctimer0_sound {
		group0 {
			pinmux = <CT0_MAT0_P2_12>;
			drive-strength = "high";
			slew-rate = "fast";
		};
	};

	flexpwm0_pwm1_pins: flexpwm0_pwm1_pins {
		group0 {
			pinmux = <PWM0_A1_P3_8>, <PWM0_B1_P3_9>;
			drive-strength = "low";
			slew-rate = "fast";
		};
	};

	flexpwm0_pwm2_pins: flexpwm0_pwm2_pins {
		group0 {
			pinmux = <PWM0_A2_P3_10>, <PWM0_B2_P3_11>;
			drive-strength = "low";
			slew-rate = "fast";
		};
	};

	/* ADC: add A0/A1/A2 (P1_10/P1_12/P1_13) alongside existing A3 (P2_0) */
	pinmux_lpadc0: pinmux_lpadc0 {
		group1 {
			pinmux = <ADC0_A8_P1_10>,   /* A0 = ANA(1) / IN(1) */
				 <ADC0_A10_P1_12>,  /* A1 = ANA(2) / IN(2) */
				 <ADC0_A11_P1_13>;  /* A2 = ANA(3) / IN(3) */
			drive-strength = "low";
			slew-rate = "fast";
		};
		/* group0: P2_0 = A3 = ANA(4) / IN(4) — defined in board pinctrl.dtsi */
	};
};

/* LPI2C0: arduino_i2c alias — enable with 400 kHz */
&lpi2c0 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;
};

/* Expand storage_partition from 16 KB (2 sectors) to 32 KB (4 × 8 KB sectors).
 * Binary is ~50 KB at 0x0; 0x18000 (96 KB) leaves ample room for code growth.
 * Sector size = 8 KB (FSL_FEATURE_SYSCON_FLASH_SECTOR_SIZE_BYTES),
 * so 4 sectors give NVS ~24 KB of usable space (1 sector reserved for GC).
 */
&flash {
	partitions {
		/delete-node/ partition@1c000;  /* remove base 16 KB storage */

		storage_partition: partition@18000 {
			label = "storage";
			reg = <0x18000 DT_SIZE_K(32)>;
		};
	};
};

/ {
	chosen {
		ij-adc        = &lpadc0;   /* ADC device for ANA()/IN() */
		ij-i2c        = &lpi2c0;  /* I2C device for I2C() command */
		ij-cvbs-timer = &ctimer1; /* Counter device for CVBS line timer (M7) */
	};

	zephyr,user {
		/* IchigoJam GPIO pin assignments for FRDM-MCXA153
		 * Using Arduino header pins. LEDs are active LOW.
		 * See pinmap/frdm_mcxa153.txt for connector layout.
		 */
		ij-led-gpios  = <&gpio3 12 GPIO_ACTIVE_LOW>;    /* RED LED (D5, shared with OUT4) */
		ij-btn-gpios  = <&gpio3 29 GPIO_ACTIVE_LOW>;    /* SW2 */
		ij-out1-gpios = <&gpio2  4 GPIO_ACTIVE_HIGH>;   /* D2 */
		ij-out2-gpios = <&gpio3  0 GPIO_ACTIVE_HIGH>;   /* D3 (BLUE LED) */
		ij-out3-gpios = <&gpio2  5 GPIO_ACTIVE_HIGH>;   /* D4 */
		ij-out4-gpios = <&gpio3 12 GPIO_ACTIVE_HIGH>;   /* D5 (RED LED, shared with ij-led) */
		ij-out5-gpios = <&gpio3 13 GPIO_ACTIVE_HIGH>;   /* D6 (GREEN LED) */
		ij-out6-gpios = <&gpio3  1 GPIO_ACTIVE_HIGH>;   /* D7 */
		ij-in1-gpios  = <&gpio1 10 GPIO_ACTIVE_HIGH>;   /* A0 */
		ij-in2-gpios  = <&gpio1 12 GPIO_ACTIVE_HIGH>;   /* A1 */
		ij-in3-gpios  = <&gpio1 13 GPIO_ACTIVE_HIGH>;   /* A2 */
		ij-in4-gpios  = <&gpio2  0 GPIO_ACTIVE_HIGH>;   /* A3 / ADC0_A0 */
		/* M7: CVBS video output pins */
		ij-cvbs-sync-gpios  = <&gpio3 14 GPIO_ACTIVE_HIGH>;  /* SYNC → 470Ω → CVBS : D9 P3_14 */
		ij-cvbs-video-gpios = <&gpio3 15 GPIO_ACTIVE_HIGH>;  /* VIDEO→ 100Ω → CVBS : D8 P3_15 */

		/*
		 * PWM specs for IchigoJam sound and OUT PWM outputs.
		 * Use standard "pwms" property (requires #pwm-cells = <3> on each
		 * referenced controller) with "pwm-names" for named access.
		 *
		 * Index mapping (must match pwm-names order):
		 *   0 = sound  : ctimer0 ch0 = CT0_MAT0 → D13 (P2_12)
		 *   1 = out1   : flexpwm0_pwm0 sm0 chA → P3_6
		 *   2 = out2   : flexpwm0_pwm0 sm0 chB → P3_7
		 *   3 = out3   : flexpwm0_pwm1 sm1 chA → P3_8
		 *   4 = out4   : flexpwm0_pwm1 sm1 chB → P3_9
		 *   5 = out5   : flexpwm0_pwm2 sm2 chA → P3_10
		 *   6 = out6   : flexpwm0_pwm2 sm2 chB → P3_11
		 *
		 * Period values are dummy (1 µs for sound, 20 ms for OUT);
		 * actual period is always set by pwm_set() at runtime.
		 */
		pwms = <&ctimer0       0 1000     PWM_POLARITY_NORMAL>,
		       <&flexpwm0_pwm0 0 20000000 PWM_POLARITY_NORMAL>,
		       <&flexpwm0_pwm0 1 20000000 PWM_POLARITY_NORMAL>,
		       <&flexpwm0_pwm1 0 20000000 PWM_POLARITY_NORMAL>,
		       <&flexpwm0_pwm1 1 20000000 PWM_POLARITY_NORMAL>,
		       <&flexpwm0_pwm2 0 20000000 PWM_POLARITY_NORMAL>,
		       <&flexpwm0_pwm2 1 20000000 PWM_POLARITY_NORMAL>;
		pwm-names = "sound", "out1", "out2", "out3", "out4", "out5", "out6";
	};
};
